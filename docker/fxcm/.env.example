# FXCM Bridge Service Environment Configuration

# Bridge API Security (optional)
FXCM_BRIDGE_API_KEY=your-secure-api-key-here

# FXCM Account Credentials
FXCM_USERNAME=your-fxcm-username
FXCM_PASSWORD=your-fxcm-password
FXCM_CONNECTION=Demo  # Demo or Real
FXCM_ACCOUNT_ID=      # Optional - leave empty to auto-detect

# Logging
LOG_LEVEL=INFO        # DEBUG, INFO, WARNING, ERROR

# Note: ForexConnect API must be downloaded separately from:
# https://fxcodebase.com/wiki/index.php/Download
# 
# Place the extracted ForexConnectAPI folder in:
# docker/fxcm/ForexConnectAPI/
#
# The folder should contain:
# - lib/
# - include/
# - samples/
# - python/