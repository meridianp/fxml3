#!/bin/bash

# FXML4 Pre-commit Hook
# Validates commit messages, runs linting, and performs basic checks

set -e

echo "🔍 FXML4 Pre-commit checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get the commit message
COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE" 2>/dev/null || echo "")

# Function to print colored output
print_status() {
    echo -e "${GREEN}✓${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

print_error() {
    echo -e "${RED}✗${NC} $1"
}

# Check if commit message follows conventional commit format
validate_commit_message() {
    echo "📝 Validating commit message format..."

    # Skip merge commits
    if echo "$COMMIT_MSG" | grep -q "^Merge"; then
        print_status "Merge commit detected, skipping validation"
        return 0
    fi

    # Skip revert commits
    if echo "$COMMIT_MSG" | grep -q "^Revert"; then
        print_status "Revert commit detected, skipping validation"
        return 0
    fi

    # Conventional commit pattern
    CONVENTIONAL_PATTERN="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?: .{1,50}"

    if echo "$COMMIT_MSG" | grep -qE "$CONVENTIONAL_PATTERN"; then
        print_status "Commit message follows conventional format"
        return 0
    else
        print_error "Commit message does not follow conventional commit format"
        echo ""
        echo "Expected format: type(scope): description"
        echo ""
        echo "Valid types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
        echo ""
        echo "Examples:"
        echo "  feat(api): add user authentication endpoint"
        echo "  fix(core): resolve memory leak in trading engine"
        echo "  docs: update installation instructions"
        echo ""
        echo "Your message: $COMMIT_MSG"
        return 1
    fi
}

# Check for Python code quality
check_python_quality() {
    echo "🐍 Checking Python code quality..."

    # Get list of staged Python files
    PYTHON_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.py$" || true)

    if [ -z "$PYTHON_FILES" ]; then
        print_status "No Python files to check"
        return 0
    fi

    # Check if black is available and run it
    if command -v black >/dev/null 2>&1; then
        echo "  Running black formatter..."
        if black --check --diff $PYTHON_FILES 2>/dev/null; then
            print_status "Python code formatting is correct"
        else
            print_warning "Python code needs formatting. Run: black $PYTHON_FILES"
            # Optionally auto-format and re-stage
            # black $PYTHON_FILES
            # git add $PYTHON_FILES
        fi
    fi

    # Check if flake8 is available and run it
    if command -v flake8 >/dev/null 2>&1; then
        echo "  Running flake8 linter..."
        if flake8 $PYTHON_FILES 2>/dev/null; then
            print_status "Python code passes linting"
        else
            print_warning "Python code has linting issues. Run: flake8 $PYTHON_FILES"
        fi
    fi

    return 0
}

# Check for JavaScript/TypeScript code quality
check_js_quality() {
    echo "📦 Checking JavaScript/TypeScript code quality..."

    # Get list of staged JS/TS files
    JS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.(js|jsx|ts|tsx)$" || true)

    if [ -z "$JS_FILES" ]; then
        print_status "No JavaScript/TypeScript files to check"
        return 0
    fi

    # Check if npm is available and package.json exists
    if [ -f "package.json" ] && command -v npm >/dev/null 2>&1; then
        # Run tests if they exist
        if npm run test:quick >/dev/null 2>&1; then
            print_status "JavaScript/TypeScript tests pass"
        else
            print_warning "Some tests may be failing"
        fi
    fi

    return 0
}

# Check for security issues
check_security() {
    echo "🔐 Checking for security issues..."

    # Check for common security patterns
    STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

    if [ -z "$STAGED_FILES" ]; then
        print_status "No files to check for security issues"
        return 0
    fi

    # Check for potential secrets
    SECRET_PATTERNS=(
        "password\s*=\s*['\"]"
        "api_key\s*=\s*['\"]"
        "secret\s*=\s*['\"]"
        "token\s*=\s*['\"]"
        "-----BEGIN.*PRIVATE KEY-----"
    )

    for pattern in "${SECRET_PATTERNS[@]}"; do
        if git diff --cached | grep -iE "$pattern" >/dev/null 2>&1; then
            print_warning "Potential secret detected in staged changes"
            break
        fi
    done

    print_status "Security check completed"
    return 0
}

# Main execution
main() {
    echo ""
    echo "🚀 Running FXML4 pre-commit hooks..."
    echo "=================================="

    # Only validate commit message if we have one
    if [ -n "$COMMIT_MSG_FILE" ] && [ -f "$COMMIT_MSG_FILE" ]; then
        validate_commit_message || exit 1
    fi

    check_python_quality || exit 1
    check_js_quality || exit 1
    check_security || exit 1

    echo ""
    print_status "All pre-commit checks passed!"
    echo ""

    return 0
}

# Run main function
main "$@"
