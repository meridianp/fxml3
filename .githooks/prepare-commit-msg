#!/bin/bash

# FXML4 Prepare Commit Message Hook
# Automatically adds branch name to commit message for feature branches

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2
SHA1=$3

# Get current branch name
BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")

# Skip if not on a feature/bugfix/hotfix branch
if [[ ! "$BRANCH_NAME" =~ ^(feature|bugfix|hotfix)/ ]]; then
    exit 0
fi

# Skip if this is a merge/revert commit
if [ "$COMMIT_SOURCE" = "merge" ] || [ "$COMMIT_SOURCE" = "squash" ]; then
    exit 0
fi

# Extract ticket/issue number from branch name if it exists
TICKET=$(echo "$BRANCH_NAME" | grep -oE "[A-Z]+-[0-9]+" | head -1)
BRANCH_SHORT=$(echo "$BRANCH_NAME" | sed 's/^[^/]*\///' | sed 's/[-_]/ /g')

# Read existing commit message
EXISTING_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip if commit message already contains branch reference
if echo "$EXISTING_MSG" | grep -q "\[$BRANCH_NAME\]"; then
    exit 0
fi

# Skip if this looks like a conventional commit already
if echo "$EXISTING_MSG" | grep -qE "^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?:"; then
    exit 0
fi

# Add branch context to commit message
if [ -n "$TICKET" ]; then
    # If we found a ticket number, add it
    printf "[$TICKET] %s\n\n%s" "$EXISTING_MSG" "$(echo "$EXISTING_MSG" | sed '1d')" > "$COMMIT_MSG_FILE"
else
    # Otherwise, just add branch context
    printf "[%s] %s" "$BRANCH_SHORT" "$EXISTING_MSG" > "$COMMIT_MSG_FILE"
fi
