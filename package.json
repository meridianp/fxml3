{
  "name": "fxml4",
  "version": "1.0.0",
  "description": "**Enterprise-grade forex trading platform with machine learning, Elliott Wave analysis, and regulatory compliance**",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "ts-jest": "^29.4.2"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "tdd:red": "jest --testNamePattern='RED:' --verbose || echo 'RED phase: Tests failed as expected'",
    "tdd:green": "jest --testNamePattern='(RED:|GREEN:)' --verbose",
    "tdd:refactor": "jest --testNamePattern='(RED:|GREEN:|REFACTOR:)' --coverage --verbose",
    "tdd:cycle": "npm run tdd:red && echo 'Implement minimal code, then run: npm run tdd:green'",
    "tdd:quick": "jest --testNamePattern='(RED:|GREEN:)' --passWithNoTests",
    "tdd:watch": "jest --watch --testNamePattern='(RED:|GREEN:|REFACTOR:)'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meridianp/fxml3.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/meridianp/fxml3/issues"
  },
  "homepage": "https://github.com/meridianp/fxml3#readme",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "jsonwebtoken": "^9.0.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^3.2.1"
  }
}
