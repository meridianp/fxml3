# FXML3 Environment Variables
# Copy this file to .env and fill in your values

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
FOREX_API_KEY=your_forex_api_key_here

# LLM Configuration
LLM_MODEL=gpt-3.5-turbo  # or gpt-4, claude-3, etc.
LOCAL_MODEL_PATH=/path/to/local/model  # for local models

# Data Sources
DATA_SOURCE=yahoo  # yahoo, fxcm, csv
DATA_CACHE_DIR=data/cache

# Model Paths
RL_MODEL_PATH=models/rl

# UI Settings
UI_PORT=8501
UI_DEBUG=false

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# API Server
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=*

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fxml3
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Authentication
API_KEYS=test_api_key_1,test_api_key_2

# API URL for UI
API_URL=http://api:8000