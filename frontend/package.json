{
  "name": "fxml4-ui",
  "version": "1.0.0",
  "description": "FXML4 Trading Platform Frontend - Professional forex trading interface with real-time data, ML training, backtesting, and live trading capabilities",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "node scripts/test-coverage.js",
    "tdd:red": "jest --testNamePattern='RED:' --verbose || echo 'RED phase: Tests failed as expected'",
    "tdd:green": "jest --testNamePattern='(RED:|GREEN:)' --verbose",
    "tdd:refactor": "jest --testNamePattern='(RED:|GREEN:|REFACTOR:)' --coverage --verbose",
    "tdd:cycle": "npm run tdd:red && echo 'Implement minimal code, then run: npm run tdd:green'",
    "tdd:quick": "jest --testNamePattern='(RED:|GREEN:)' --passWithNoTests",
    "tdd:watch": "jest --watch --testNamePattern='(RED:|GREEN:|REFACTOR:)'",
    "test:unit": "jest src/**/__tests__/**/*.test.ts --testNamePattern=\"^((?!integration).)*$\"",
    "test:integration": "jest src/**/__tests__/**/*.integration.test.ts",
    "test:component": "jest src/components/**/__tests__/**/*.test.tsx",
    "test:all": "node scripts/run-all-tests.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:full": "ts-node e2e/test-runner.ts",
    "test:e2e:auth": "playwright test e2e/core/authentication.spec.ts",
    "test:e2e:navigation": "playwright test e2e/core/navigation.spec.ts",
    "test:e2e:data": "playwright test e2e/features/data-management.spec.ts",
    "test:e2e:trading": "playwright test e2e/features/trading-console.spec.ts",
    "test:e2e:analytics": "playwright test e2e/features/analytics-dashboard.spec.ts",
    "test:e2e:ml": "playwright test e2e/features/ml-training.spec.ts",
    "test:e2e:performance": "playwright test e2e/performance/performance.spec.ts",
    "test:e2e:chrome": "playwright test --project chromium",
    "test:e2e:firefox": "playwright test --project firefox",
    "test:e2e:webkit": "playwright test --project webkit",
    "test:e2e:mobile": "playwright test --project mobile-chrome",
    "test:performance": "node scripts/performance-testing.js",
    "test:performance:quick": "playwright test e2e/performance/performance-test-scenarios.ts --project chromium",
    "test:performance:load": "playwright test e2e/performance/performance.spec.ts",
    "test:performance:regression": "playwright test e2e/performance/performance-test-scenarios.ts -g 'performance regression detection'",
    "test:performance:mobile": "playwright test e2e/performance/performance-test-scenarios.ts -g 'mobile performance'",
    "test:performance:ci": "npm run test:performance:quick && npm run test:performance:regression",
    "test:visual": "node scripts/visual-regression-testing.js",
    "test:visual:quick": "VISUAL_TEST_CATEGORY=smoke npm run test:visual",
    "test:visual:regression": "VISUAL_TEST_CATEGORY=regression npm run test:visual",
    "test:visual:comprehensive": "VISUAL_TEST_CATEGORY=comprehensive npm run test:visual",
    "test:visual:update": "UPDATE_VISUAL_BASELINES=true npm run test:visual",
    "test:visual:chrome": "playwright test e2e/visual/ --project chrome-visual",
    "test:visual:firefox": "playwright test e2e/visual/ --project firefox-visual",
    "test:visual:safari": "playwright test e2e/visual/ --project safari-visual",
    "test:visual:mobile": "playwright test e2e/visual/ --project mobile-chrome-visual mobile-safari-visual",
    "test:visual:ci": "npm run test:visual:quick && npm run test:visual:regression",
    "analyze": "ANALYZE=true npm run build",
    "analyze:bundle": "node scripts/bundle-analyzer.js",
    "analyze:full": "npm run analyze && npm run analyze:bundle",
    "build:analyze": "npm run analyze",
    "bundle:size": "npm run build && bundlesize",
    "optimize": "npm run analyze:full && npm run test:performance:quick",
    "lazy-load:test": "jest src/**/__tests__/**/*lazy*.test.ts",
    "performance:monitor": "npm run dev --silent &",
    "performance:profile": "NODE_ENV=production npm run build && npm run analyze",
    "deploy:docker": "./scripts/deploy.sh deploy",
    "deploy:k8s": "kubectl apply -f k8s/",
    "health:check": "./scripts/production-health-check.sh check",
    "health:report": "./scripts/production-health-check.sh report",
    "production:build": "NODE_ENV=production npm run build",
    "production:start": "NODE_ENV=production npm start",
    "production:deploy": "./scripts/deploy.sh deploy production",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@headlessui/react": "^1.7.0",
    "@heroicons/react": "^2.1.0",
    "@hookform/resolvers": "^3.3.0",
    "@next/font": "^14.1.0",
    "@radix-ui/react-tabs": "^1.1.12",
    "@tailwindcss/forms": "^0.5.0",
    "@tailwindcss/typography": "^0.5.0",
    "@tanstack/react-query": "^5.17.0",
    "@tanstack/react-table": "^8.11.0",
    "@tanstack/react-virtual": "^3.0.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "axe-core": "^4.10.3",
    "axios": "^1.6.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.0",
    "framer-motion": "^11.0.0",
    "jest-axe": "^10.0.0",
    "lightweight-charts": "^4.1.0",
    "lucide-react": "^0.321.0",
    "next": "^14.1.0",
    "next-pwa": "^5.6.0",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.0",
    "react-hot-toast": "^2.4.0",
    "recharts": "^2.10.0",
    "socket.io-client": "^4.7.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "workbox-webpack-plugin": "^7.3.0",
    "zod": "^3.22.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@storybook/addon-essentials": "^7.6.0",
    "@storybook/addon-interactions": "^7.6.0",
    "@storybook/addon-links": "^7.6.0",
    "@storybook/blocks": "^7.6.0",
    "@storybook/nextjs": "^7.6.0",
    "@storybook/react": "^7.6.0",
    "@storybook/testing-library": "^0.2.0",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "bundlesize": "^0.18.0",
    "compression-webpack-plugin": "^10.0.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.1.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "gzip-size": "^6.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lodash-es": "^4.17.21",
    "playwright": "^1.55.0",
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "react-intersection-observer": "^9.5.2",
    "storybook": "^7.6.0",
    "ts-jest": "^29.1.0",
    "web-vitals": "^3.3.2",
    "webpack-bundle-analyzer": "^4.9.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "bundlesize": [
    {
      "path": ".next/static/js/*.js",
      "maxSize": "250 kB"
    },
    {
      "path": ".next/static/css/*.css",
      "maxSize": "50 kB"
    }
  ]
}
