# FXML4 Redesigned Environment Configuration

# Database Configuration
DB_HOST=timescaledb
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=fxml4_trading

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=admin
RABBITMQ_PASS=admin123

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Interactive Brokers Configuration
IB_GATEWAY_HOST=127.0.0.1
IB_GATEWAY_PORT=7497  # 7497 for paper trading, 7496 for live trading
IB_CLIENT_ID=1

# LLM API Keys (Optional - for testing without real keys)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Service Configuration
LOG_LEVEL=INFO
DEBUG=false

# Trading Configuration
TRADING_MODE=paper  # paper or live
MAX_RISK_PER_TRADE=0.02  # 2% risk per trade
MAX_DAILY_LOSS=0.05      # 5% max daily loss
BASE_LEVERAGE=50         # Base leverage multiplier

# Monitoring Configuration
ALERT_EMAIL=your-email@example.com
SLACK_WEBHOOK_URL=your_slack_webhook_url
