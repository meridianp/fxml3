  "shortcuts": [
    {
      "name": "Trading Console",
      "short_name": "Trade",
      "description": "Quick access to live trading console",
      "url": "/trading",
      "icons": [
        {
          "src": "/images/icons/trading-shortcut.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Analytics",
      "short_name": "Analytics",
      "description": "View performance analytics and reports",
      "url": "/analytics",
      "icons": [
        {
          "src": "/images/icons/analytics-shortcut.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Market Data",
      "short_name": "Data",
      "description": "Real-time market data and feeds",
      "url": "/data",
      "icons": [
        {
          "src": "/images/icons/data-shortcut.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "file",
          "accept": ["image/*", ".csv", ".json", ".txt"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+fxml4",
      "url": "/handle?data=%s"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "related_applications": [],
  "prefer_related_applications": false,
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"]
}
