# FXML4 Trading Platform - Environment Configuration

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Application Configuration  
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_VERSION=1.0.0

# Feature Flags
NEXT_PUBLIC_ENABLE_LIVE_TRADING=true
NEXT_PUBLIC_ENABLE_ML_TRAINING=true
NEXT_PUBLIC_ENABLE_BACKTESTING=true
NEXT_PUBLIC_ENABLE_DARK_MODE=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_ADVANCED_CHARTS=true

# Trading Configuration
NEXT_PUBLIC_DEFAULT_TIMEFRAME=1h
NEXT_PUBLIC_MAX_POSITION_SIZE=1000000
NEXT_PUBLIC_DEFAULT_LEVERAGE=100

# Analytics (Optional)
NEXT_PUBLIC_GA_TRACKING_ID=
NEXT_PUBLIC_GTAG_ID=

# Error Tracking (Optional)
NEXT_PUBLIC_SENTRY_DSN=

# Development Tools
NEXT_PUBLIC_ENABLE_DEBUG_LOGS=true
NEXT_PUBLIC_ENABLE_REDUX_DEVTOOLS=true
NEXT_PUBLIC_MOCK_API=false
NEXT_PUBLIC_MOCK_WEBSOCKET=false

# Security
NEXT_PUBLIC_CSP_ENABLED=true
NEXT_PUBLIC_SECURE_HEADERS=true

# Performance Monitoring
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true
NEXT_PUBLIC_ENABLE_WEB_VITALS=true