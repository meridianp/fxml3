# FXML4 Git Attributes Configuration
# Ensures consistent behavior across different operating systems

# Set default behavior to automatically normalize line endings
* text=auto eol=lf

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.bat text eol=crlf

# Configuration files
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.gitmessage text eol=lf
.gitflow text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.less text eol=lf

# Data files
*.csv text eol=lf
*.sql text eol=lf
*.xml text eol=lf

# Docker files
Dockerfile text eol=lf
*.dockerfile text eol=lf
docker-compose*.yml text eol=lf

# Declare files that will always have CRLF line endings on checkout
*.sln text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Python specific
*.pyc binary
*.pyo binary
*.pyd binary
*.whl binary
*.egg binary

# Node.js specific
node_modules/ binary

# Archives
*.7z binary
*.gz binary
*.rar binary
*.tar binary
*.tgz binary

# Fonts
*.eot binary
*.otf binary
*.ttf binary
*.woff binary
*.woff2 binary

# Trading/Financial data files
*.tick binary
*.bar binary
*.candle binary

# Machine learning models
*.pkl binary
*.joblib binary
*.h5 binary
*.hdf5 binary
*.pb binary

# Database files
*.db binary
*.sqlite binary
*.sqlite3 binary

# Export diff and merge tools for specific file types
*.py diff=python
*.js diff=javascript
*.jsx diff=javascript
*.ts diff=typescript
*.tsx diff=typescript

# Treat documentation as text but don't merge automatically
CHANGELOG.md merge=ours
RELEASE_NOTES.md merge=ours

# Large files that should be tracked with Git LFS (if needed)
# Uncomment and modify as needed
# *.zip filter=lfs diff=lfs merge=lfs -text
# *.gz filter=lfs diff=lfs merge=lfs -text
# *.tar filter=lfs diff=lfs merge=lfs -text

# Generated files - exclude from language statistics
/frontend/build/* linguist-generated=true
/frontend/dist/* linguist-generated=true
/docs/_build/* linguist-generated=true
*.min.js linguist-generated=true
*.min.css linguist-generated=true

# Vendor files - exclude from language statistics
/frontend/node_modules/* linguist-vendored=true
/venv/* linguist-vendored=true
/vendor/* linguist-vendored=true

# Mark specific languages for GitHub language detection
*.py linguist-language=Python
*.js linguist-language=JavaScript
*.ts linguist-language=TypeScript
*.tsx linguist-language=TypeScript
